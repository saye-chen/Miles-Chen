{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crossborder.local/capm/rights_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["rights_id", "rights_version", "content_id", "content_version", "creator_id", "start_at", "end_at", "as_of_time", "granted", "requested", "requested_actions", "evidence_ids"],
  "properties": {
    "rights_id": {"type": "string", "minLength": 1},
    "rights_version": {"type": "string", "minLength": 1},
    "content_id": {"type": "string", "minLength": 1},
    "content_version": {"type": "string", "minLength": 1},
    "requested_content_version": {"type": "string", "minLength": 1},
    "creator_id": {"type": "string", "minLength": 1},
    "start_at": {"type": "string", "format": "date-time"},
    "end_at": {"type": "string", "format": "date-time"},
    "as_of_time": {"type": "string", "format": "date-time"},
    "revoked_at": {"type": ["string", "null"], "format": "date-time"},
    "granted": {"$ref": "#/$defs/useGrid"},
    "requested": {"$ref": "#/$defs/useGrid"},
    "requested_actions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
  },
  "$defs": {
    "useGrid": {"type": "object", "additionalProperties": false, "required": ["platform", "use", "territory", "edit", "identity_use", "ai_use"], "properties": {"platform": {"$ref": "#/$defs/strings"}, "use": {"$ref": "#/$defs/strings"}, "territory": {"$ref": "#/$defs/strings"}, "edit": {"$ref": "#/$defs/strings"}, "identity_use": {"$ref": "#/$defs/strings"}, "ai_use": {"$ref": "#/$defs/strings"}}},
    "strings": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
